# --- server ---
PORT=3000
# Robinhood Chain RPC (public default works, a private one is faster)
RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Vault key encryption (REQUIRED for managed fee modes)
# Generate: openssl rand -base64 32   (never commit the real value)
VAULT_ENCRYPTION_KEY=

# Admin panel + bot reporting
ADMIN_TOKEN=

# --- bot ---
# true = log only, send nothing on-chain. Flip to false to go live.
DRY_RUN=true
BOT_POLL_SECONDS=60
# Minimum ETH in the vault before a payout is worth the gas
MIN_DISTRIBUTE_ETH=0.001
# ETH kept in the vault for gas
GAS_RESERVE_WEI=200000000000000
# Site the bot reads launches from
SITE_URL=http://localhost:3000

# --- misc ---
# Used if CoinGecko is unreachable
ETH_USD_FALLBACK=3000
# Set to false to run the web server without the indexer
INDEXER=true
